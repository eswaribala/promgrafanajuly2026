name: dockercompose16431188638145401554
services:
  grafana:
    environment:
      GF_SECURITY_ADMIN_PASSWORD: P@ssw0rd
    image: grafana/grafana
    networks:
      default: null
    ports:
      - mode: ingress
        target: 3000
        published: "3000"
        protocol: tcp
    restart: always
  inventoryapi:
    build:
      context: E:\IntelJun2023\InventoryAPI
      dockerfile: InventoryAPI/Dockerfile
      args:
        BUILD_CONFIGURATION: Debug
        LAUNCHING_FROM_VS: "true"
      labels:
        com.microsoft.created-by: visual-studio
        com.microsoft.visual-studio.project-name: InventoryAPI
      target: base
    depends_on:
      sqlserverinventoryservice:
        condition: service_started
        required: true
    entrypoint:
      - dotnet
      - --roll-forward
      - Major
      - /VSTools/DistrolessHelper/DistrolessHelper.dll
      - --wait
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_LOGGING__CONSOLE__DISABLECOLORS: "true"
      ASPNETCORE_URLS: https://+:443;http://+:80
      DOTNET_USE_POLLING_FILE_WATCHER: "1"
      NUGET_FALLBACK_PACKAGES: /.nuget/fallbackpackages
    image: inventoryapi:dev
    labels:
      com.microsoft.visualstudio.debuggee.arguments: ' --additionalProbingPath /.nuget/packages --additionalProbingPath /.nuget/fallbackpackages  "/app/bin/Debug/net8.0/InventoryAPI.dll"'
      com.microsoft.visualstudio.debuggee.killprogram: dotnet --roll-forward Major /VSTools/DistrolessHelper/DistrolessHelper.dll --stop dotnet
      com.microsoft.visualstudio.debuggee.program: dotnet
      com.microsoft.visualstudio.debuggee.workingdirectory: /app
    networks:
      default: null
    ports:
      - mode: ingress
        target: 80
        published: "8085"
        protocol: tcp
      - mode: ingress
        target: 443
        published: "8087"
        protocol: tcp
      - mode: ingress
        target: 80
        protocol: tcp
      - mode: ingress
        target: 443
        protocol: tcp
    tty: true
    volumes:
      - type: bind
        source: C:\Users\param\AppData\Roaming\Microsoft\UserSecrets
        target: /root/.microsoft/usersecrets
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\param\AppData\Roaming\ASP.NET\Https
        target: /root/.aspnet/https
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: E:\IntelJun2023\InventoryAPI\InventoryAPI
        target: /app
        bind:
          create_host_path: true
      - type: bind
        source: E:\IntelJun2023\InventoryAPI
        target: /src
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\param\vsdbg\vs2017u5
        target: /remote_debugger
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\param\.nuget\packages
        target: /.nuget/packages
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: d:\Program Files (x86)\Microsoft Visual Studio\Shared\NuGetPackages
        target: /.nuget/fallbackpackages
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\param\AppData\Roaming\ASP.NET\Https
        target: /home/app/.aspnet/https
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\param\AppData\Roaming\Microsoft\UserSecrets
        target: /home/app/.microsoft/usersecrets
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Program Files\Microsoft Visual Studio\18\Enterprise\MSBuild\Sdks\Microsoft.Docker.Sdk\tools\linux-x64\net8.0
        target: /VSTools
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Program Files\Microsoft Visual Studio\18\Enterprise\Common7\IDE\extensions\Microsoft\managedprojectsystem\HotReload
        target: /HotReloadAgent
        read_only: true
        bind:
          create_host_path: true
  prometheus:
    image: prom/prometheus
    networks:
      default: null
    ports:
      - mode: ingress
        target: 9090
        published: "9090"
        protocol: tcp
    restart: always
    volumes:
      - type: bind
        source: E:\IntelJun2023\InventoryAPI\prometheus.yml
        target: /etc/prometheus43543/prometheus.yml
        read_only: true
        bind:
          create_host_path: true
  sqlserverinventoryservice:
    environment:
      ACCEPT_EULA: "Y"
      SA_PASSWORD: Vignesh@95
    expose:
      - "1433"
    hostname: sqlserverinventoryservice
    image: mcr.microsoft.com/mssql/server
    networks:
      default: null
    ports:
      - mode: ingress
        target: 1433
        published: "1406"
        protocol: tcp
    volumes:
      - type: bind
        source: E:\IntelJun2023\InventoryAPI\invapi
        target: /var/opt/mssql/data
        bind:
          create_host_path: true
networks:
  default:
    name: dockercompose16431188638145401554_default